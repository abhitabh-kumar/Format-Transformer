<idea-plugin>
    <id>com.jsonformatter.format-transformer</id>
    <name>Format Transformer</name>
    <vendor email="support@jsonformatter.dev" url="https://github.com/jsonformatter/format-transformer">
        Format Transformer Team
    </vendor>

    <description><![CDATA[
        <p>Convert JSON into developer-friendly formats directly inside IntelliJ IDEA.</p>
        <p>Fully offline. No AI. No cloud. No API calls.</p>
        <ul>
            <li>application.properties, YAML, XML, Text, CSV, Markdown, Java Map, Java Properties</li>
            <li>Nested objects, arrays, booleans, numbers, strings, and null values</li>
            <li>Extensible converter engine for future formats</li>
            <li>Opens converted output in a new editor tab without modifying the original file</li>
        </ul>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <notificationGroup id="Format Transformer"
                           displayType="BALLOON"
                           isLogByDefault="true"/>

        <projectActivity implementation="com.jsonformatter.welcome.WelcomeStartupActivity"/>

        <projectConfigurable parentId="tools"
                             instance="com.jsonformatter.settings.FormatTransformerConfigurable"
                             id="com.jsonformatter.settings.FormatTransformerConfigurable"
                             displayName="Format Transformer"/>
    </extensions>

    <actions>
        <group id="FormatTransformer.ConvertJsonGroup"
               class="com.jsonformatter.actions.ConvertJsonActionGroup"
               text="Convert JSON"
               popup="true"
               icon="/icons/pluginIcon.svg">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
            <add-to-group group-id="MainToolBar" anchor="last"/>
        </group>
    </actions>
</idea-plugin>
